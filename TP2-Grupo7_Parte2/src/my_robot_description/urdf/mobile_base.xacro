<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="package_name" default="my_robot_description"/>
  <xacro:arg name="mesh_dir" default="meshes"/>
  <xacro:arg name="publish_diffdrive_tf" default="true"/>

  <xacro:property name="global_scale" value="1.0"/>

  <xacro:property name="base_mesh" value="base_link.STL"/>
  <xacro:property name="base_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="base_visual_xyz" value="0 0 0"/>
  <xacro:property name="base_visual_rpy" value="0 0 3.14159"/>

  <xacro:property name="left_wheel_mesh" value="Rueda_izquierda_link.STL"/>
  <xacro:property name="left_wheel_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="left_wheel_xyz" value="0.033259 0.08025 -0.01375"/>
  <xacro:property name="left_wheel_rpy" value="0 0 0"/>
  <xacro:property name="left_wheel_axis" value="0 1 0"/>
  <xacro:property name="left_wheel_visual_xyz" value="0 0 0"/>
  <xacro:property name="left_wheel_visual_rpy" value="-1.5708 0.042481 0"/>

  <xacro:property name="right_wheel_mesh" value="Rueda_derecha_link.STL"/>
  <xacro:property name="right_wheel_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="right_wheel_xyz" value="0.033259 -0.08025 -0.01375"/>
  <xacro:property name="right_wheel_rpy" value="0 0 0"/>
  <xacro:property name="right_wheel_axis" value="0 1 0"/>
  <xacro:property name="right_wheel_visual_xyz" value="0 0 0"/>
  <xacro:property name="right_wheel_visual_rpy" value="-1.5708 0.042481 0"/>

  <xacro:property name="castor_base_mesh" value="Base_castor_link.STL"/>
  <xacro:property name="castor_base_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="castor_base_xyz" value="-0.072581 0 -0.0025"/>
  <xacro:property name="castor_base_rpy" value="3.14 0 3.14"/>
  <xacro:property name="castor_base_axis" value="0 0 1"/>
  <xacro:property name="castor_base_visual_xyz" value="0 0 0"/>
  <xacro:property name="castor_base_visual_rpy" value="0 0 0"/>

  <xacro:property name="castor_wheel_mesh" value="Rueda_castor_link.STL"/>
  <xacro:property name="castor_wheel_scale" value="${global_scale} ${global_scale} ${global_scale}"/>
  <xacro:property name="castor_wheel_xyz" value="0.015014 0.00012272 0.02296"/>
  <xacro:property name="castor_wheel_rpy" value="3.14 3.14 -3.14"/>
  <xacro:property name="castor_wheel_axis" value="0 1 0"/>
  <xacro:property name="castor_wheel_visual_xyz" value="0 0 0"/>
  <xacro:property name="castor_wheel_visual_rpy" value="1.5708 0 0"/>

  <xacro:property name="wheel_separation" value="0.159"/>
  <xacro:property name="wheel_radius" value="0.033"/>
  <xacro:property name="robot_length" value="0.185"/>
  <xacro:property name="robot_width" value="0.145"/>
  <xacro:property name="robot_height" value="0.050"/>

  <xacro:property name="base_mass" value="0.8"/>
  <xacro:property name="wheel_mass" value="0.05"/>
  <xacro:property name="castor_base_mass" value="0.02"/>
  <xacro:property name="castor_wheel_mass" value="0.02"/>
  <xacro:property name="lidar_mass" value="0.1"/>

  <xacro:property name="wheel_collision_radius" value="0.033"/>
  <xacro:property name="wheel_collision_length" value="0.020"/>
  <xacro:property name="castor_wheel_collision_radius" value="0.0125"/>
  <xacro:property name="lidar_collision_radius" value="0.03"/>
  <xacro:property name="lidar_collision_length" value="0.04"/>

  <xacro:property name="camara_size_x" value="0.015"/>
  <xacro:property name="camara_size_y" value="0.025"/>
  <xacro:property name="camara_size_z" value="0.020"/>


  <xacro:macro name="inertial_box" params="mass x y z *origin">
    <inertial>
      <xacro:insert_block name="origin"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (y*y + z*z)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0) * mass * (x*x + z*z)}"
        iyz="0.0"
        izz="${(1.0/12.0) * mass * (x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertial_cylinder" params="mass radius length *origin">
    <inertial>
      <xacro:insert_block name="origin"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        ixy="0.0" ixz="0.0"
        iyy="${(1.0/12.0) * mass * (3*radius*radius + length*length)}"
        iyz="0.0"
        izz="${(1.0/2.0) * mass * radius*radius}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertial_sphere" params="mass radius *origin">
    <inertial>
      <xacro:insert_block name="origin"/>
      <mass value="${mass}"/>
      <inertia
        ixx="${(2.0/5.0) * mass * radius*radius}"
        ixy="0.0" ixz="0.0"
        iyy="${(2.0/5.0) * mass * radius*radius}"
        iyz="0.0"
        izz="${(2.0/5.0) * mass * radius*radius}"/>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="${base_visual_xyz}" rpy="${base_visual_rpy}"/>
      <geometry>
        <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${base_mesh}" scale="${base_scale}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${robot_length} ${robot_width} ${robot_height}"/>
      </geometry>
    </collision>
    <xacro:inertial_box mass="${base_mass}" x="${robot_length}" y="${robot_width}" z="${robot_height}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <link name="Rueda_izquierda_link">
    <visual>
      <origin xyz="${left_wheel_visual_xyz}" rpy="${left_wheel_visual_rpy}"/>
      <geometry>
        <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${left_wheel_mesh}" scale="${left_wheel_scale}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_collision_radius}" length="${wheel_collision_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="${wheel_mass}" radius="${wheel_collision_radius}" length="${wheel_collision_length}">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <link name="Rueda_derecha_link">
    <visual>
      <origin xyz="${right_wheel_visual_xyz}" rpy="${right_wheel_visual_rpy}"/>
      <geometry>
        <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${right_wheel_mesh}" scale="${right_wheel_scale}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="${wheel_collision_radius}" length="${wheel_collision_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="${wheel_mass}" radius="${wheel_collision_radius}" length="${wheel_collision_length}">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <link name="Base_castor_link">
    <visual>
      <origin xyz="${castor_base_visual_xyz}" rpy="${castor_base_visual_rpy}"/>
      <geometry>
        <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${castor_base_mesh}" scale="${castor_base_scale}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <xacro:inertial_box mass="${castor_base_mass}" x="0.02" y="0.02" z="0.01">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <link name="Rueda_castor_link">
    <visual>
      <origin xyz="${castor_wheel_visual_xyz}" rpy="${castor_wheel_visual_rpy}"/>
      <geometry>
        <mesh filename="package://$(arg package_name)/$(arg mesh_dir)/${castor_wheel_mesh}" scale="${castor_wheel_scale}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${castor_wheel_collision_radius}"/>
      </geometry>
    </collision>
    <xacro:inertial_sphere mass="${castor_wheel_mass}" radius="${castor_wheel_collision_radius}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_sphere>
  </link>

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_collision_radius}" length="${lidar_collision_length}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_collision_radius}" length="${lidar_collision_length}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="${lidar_mass}" radius="${lidar_collision_radius}" length="${lidar_collision_length}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <link name="imu_link"/>

  <!-- Camara -->
  <link name="camara_link">
    <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="1e-6" ixy="0" ixz="0"
                 iyy="1e-6" iyz="0"
                 izz="1e-6" />
    </inertial>
    <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="${camara_size_x} ${camara_size_y} ${camara_size_z}"/>
        </geometry>
        <material name="">
            <color rgba="0.1 0.1 0.1 1"/>
        </material>
    </visual>
    <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
            <box size="${camara_size_x} ${camara_size_y} ${camara_size_z}"/>
        </geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.04675" rpy="0 0 0"/>
  </joint>

  <joint name="Rueda_izquierda_joint" type="continuous">
    <origin xyz="${left_wheel_xyz}" rpy="${left_wheel_rpy}"/>
    <parent link="base_link"/>
    <child link="Rueda_izquierda_link"/>
    <axis xyz="${left_wheel_axis}"/>
  </joint>

  <joint name="Rueda_derecha_joint" type="continuous">
    <origin xyz="${right_wheel_xyz}" rpy="${right_wheel_rpy}"/>
    <parent link="base_link"/>
    <child link="Rueda_derecha_link"/>
    <axis xyz="${right_wheel_axis}"/>
  </joint>

  <joint name="Base_castor_joint" type="continuous">
    <origin xyz="${castor_base_xyz}" rpy="${castor_base_rpy}"/>
    <parent link="base_link"/>
    <child link="Base_castor_link"/>
    <axis xyz="${castor_base_axis}"/>
  </joint>

  <joint name="Rueda_castor_joint" type="continuous">
    <origin xyz="${castor_wheel_xyz}" rpy="${castor_wheel_rpy}"/>
    <parent link="Base_castor_link"/>
    <child link="Rueda_castor_link"/>
    <axis xyz="${castor_wheel_axis}"/>
  </joint>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <joint name="camara_joint" type="fixed">
    <origin
        xyz="${robot_length/2.0 + camara_size_x/2.0} 0 -0.001"
        rpy="0 0 0" />
    <parent
        link="base_link" />
    <child
        link="camara_link" />
  </joint>


  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>Rueda_izquierda_joint</left_joint>
      <right_joint>Rueda_derecha_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <xacro:if value="$(arg publish_diffdrive_tf)">
        <tf_topic>/tf</tf_topic>
      </xacro:if>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      </plugin>
      <plugin filename="gz-sim-odometry-publisher-system"
          name="gz::sim::systems::OdometryPublisher">
      <odom_topic>odom_real</odom_topic>
      <odom_publish_frequency>50</odom_publish_frequency>
      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu"/>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <topic>scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <update_rate>10</update_rate>
      <always_on>1</always_on>
      <visualize>true</visualize>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.141592</min_angle>
            <max_angle>3.141592</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.08</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

  <!-- plugin Camara -->
  <gazebo reference="camara_link">
    <sensor name="camara_meta" type="camera">
        <pose relative_to="camara_link">0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <topic>camera/image_raw</topic>
        <update_rate>15</update_rate>
        <gz_frame_id>camara_link</gz_frame_id>

        <camera name="camara_meta">
            <horizontal_fov>1.047</horizontal_fov>  <!-- ~60 grados -->
            <image>
                <width>320</width>
                <height>240</height>
                <format>R8G8B8</format>
            </image>
            <clip>
                <near>0.05</near>
                <far>10.0</far>
            </clip>
            <noise>
                <type>gaussian</type>
                <mean>0.0</mean>
                <stddev>0.007</stddev>
            </noise>
        </camera>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu" type="imu">
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <update_rate>100</update_rate>
      <always_on>1</always_on>
      <imu>
        <orientation_reference_frame>
          <localization>ENU</localization>
        </orientation_reference_frame>
      </imu>
    </sensor>
  </gazebo>

</robot>